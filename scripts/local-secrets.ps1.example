# Copy to "local-secrets.ps1" in this folder (gitignored). Fill in your real values.
# Use single quotes for passwords so characters like @ are never interpreted by PowerShell.
#
# MySQL 1045 "Access denied": MYSQL_PASSWORD must match Workbench exactly (case-sensitive).

$env:MYSQL_HOST = 'localhost'
$env:MYSQL_PORT = '3306'
$env:MYSQL_DB = 'smartcampus'
$env:MYSQL_USER = 'root'
$env:MYSQL_PASSWORD = 'REPLACE_WITH_EXACT_MYSQL_ROOT_PASSWORD'

$env:GOOGLE_CLIENT_ID = 'REPLACE'
$env:GOOGLE_CLIENT_SECRET = 'REPLACE'

$env:AWS_S3_PROFILE_BUCKET = 'REPLACE'
$env:AWS_S3_PROFILE_REGION = 'ap-south-1'
$env:AWS_S3_PROFILE_KEY_PREFIX = 'Profile-images/'
$env:AWS_S3_PROFILE_PUBLIC_BASE_URL = 'REPLACE'
$env:AWS_ACCESS_KEY_ID = 'REPLACE'
$env:AWS_SECRET_ACCESS_KEY = 'REPLACE'

$env:SPRING_MAIL_HOST = 'smtp.gmail.com'
$env:SPRING_MAIL_PORT = '587'
$env:SPRING_MAIL_USERNAME = 'REPLACE@gmail.com'
$env:SPRING_MAIL_PASSWORD = 'REPLACE_APP_PASSWORD'
